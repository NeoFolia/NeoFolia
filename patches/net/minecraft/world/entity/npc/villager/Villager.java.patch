+
+    private Predicate<Holder<PoiType>> poiReleasePredicate(MemoryModuleType<GlobalPos> memoryType) {
+        if (memoryType == MemoryModuleType.HOME) {
+            return poiType -> poiType.is(PoiTypes.HOME);
+        }
+        if (memoryType == MemoryModuleType.JOB_SITE) {
+            Holder<VillagerProfession> profession = this.getVillagerData().profession();
+            return poiType -> profession.value().heldJobSite().test(poiType);
+        }
+        if (memoryType == MemoryModuleType.POTENTIAL_JOB_SITE) {
+            return VillagerProfession.ALL_ACQUIRABLE_JOBS;
+        }
+        if (memoryType == MemoryModuleType.MEETING_POINT) {
+            return poiType -> poiType.is(PoiTypes.MEETING);
+        }
+
+        return null;
+    }
+
+    private static void releasePoiAt(ServerLevel poiLevel, BlockPos pos, Predicate<Holder<PoiType>> poiTypePredicate) {
+        PoiManager poiManager = poiLevel.getPoiManager();
+        Optional<Holder<PoiType>> type = poiManager.getType(pos);
+        if (type.isPresent() && poiTypePredicate.test(type.get())) {
+            poiManager.release(pos);
+            poiLevel.debugSynchronizers().updatePoi(pos);
         }
     }
 
