+    private static void assignProfessionFromJobSite(ServerLevel level, Villager body, GlobalPos pos) {
+        MinecraftServer server = level.getServer();
+        ServerLevel poiLevel = server.getLevel(pos.dimension());
+        if (poiLevel == null) {
+            return;
+        }
+
+        if (RegionizedWorldGuard.scheduleAtRegionIfRegionizedOutsideRegion(
+            poiLevel, pos.pos(), "Villager profession assignment", () -> assignProfessionFromJobSite(level, body, pos)
+        )) {
+            return;
+        }
+
+        poiLevel.getPoiManager()
+            .getType(pos.pos())
+            .flatMap(
+                poiType -> BuiltInRegistries.VILLAGER_PROFESSION
+                    .listElements()
+                    .filter(profession -> profession.value().heldJobSite().test((Holder<PoiType>)poiType))
+                    .findFirst()
+            )
+            .ifPresent(profession -> applyProfessionOnEntityRegion(level, body, profession));
+    }
+
+    private static void applyProfessionOnEntityRegion(ServerLevel level, Villager body, Holder<VillagerProfession> profession) {
+        if (RegionizedWorldGuard.scheduleEntityIfRegionizedOutsideRegion(
+            level, body, "Villager profession assignment apply", () -> applyProfessionOnEntityRegion(level, body, profession)
+        )) {
+            return;
+        }
+
+        body.setVillagerData(body.getVillagerData().withProfession(profession));
+        body.refreshBrain(level);
     }
