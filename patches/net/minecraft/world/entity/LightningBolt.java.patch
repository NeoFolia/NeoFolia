+        Set<Entity> hitEntitiesSnapshot;
+        synchronized (this.hitEntities) {
+            hitEntitiesSnapshot = Set.copyOf(this.hitEntities);
+        }
+        AABB regionBox = RegionizedWorldGuard.restrictToCurrentRegion(level, viewerBox);
+        List<Entity> viewers = regionBox == null
+            ? List.of()
+            : List.copyOf(level.getEntities(this, regionBox, entityx -> entityx.isAlive() && !hitEntitiesSnapshot.contains(entityx)));
+
+        Runnable trigger = () -> this.triggerLightningStrikeGlobal(level, lightningX, lightningY, lightningZ, viewers);
+        if (!RegionizedWorldGuard.scheduleGlobalIfRegionized(level, "Lightning strike advancement", trigger)) {
+            trigger.run();
+        }
+    }
+
+    private void triggerLightningStrikeGlobal(ServerLevel level, double lightningX, double lightningY, double lightningZ, List<Entity> viewers) {
+        for (ServerPlayer player : level.getServer().getPlayerList().getPlayersAcrossRegions()) {
+            RegionizedWorldGuard.executeOnPlayerRegion(player, () -> {
+                if (player.level() == level && player.distanceToSqr(lightningX, lightningY, lightningZ) < 65536.0) {
+                    CriteriaTriggers.LIGHTNING_STRIKE.trigger(player, this, viewers);
+                }
+            });
+        }
+    }
