+    private void triggerFishingRodHooked(ServerPlayer owner, ItemStack rod, List<ItemStack> items) {
+        ItemStack rodSnapshot = rod.copy();
+        List<ItemStack> itemSnapshots = items.stream().map(ItemStack::copy).toList();
+        Runnable trigger = () -> RegionizedWorldGuard.executeOnPlayerRegion(
+            owner, () -> CriteriaTriggers.FISHING_ROD_HOOKED.trigger(owner, rodSnapshot, this, itemSnapshots)
+        );
+        if (!RegionizedWorldGuard.scheduleGlobalIfRegionized(this.level(), "Fishing rod hooked advancement", trigger)) {
+            trigger.run();
+        }
+    }
+
