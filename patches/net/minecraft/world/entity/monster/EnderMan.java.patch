+
+    private static boolean canReadBlock(Level level, BlockPos pos) {
+        return RegionizedWorldGuard.shouldLoadChunk(level, pos.getX() >> 4, pos.getZ() >> 4);
+    }
+
+    private static boolean canReadBetween(Level level, Vec3 from, Vec3 to) {
+        int minChunkX = Mth.floor(Math.min(from.x, to.x)) >> 4;
+        int maxChunkX = Mth.floor(Math.max(from.x, to.x)) >> 4;
+        int minChunkZ = Mth.floor(Math.min(from.z, to.z)) >> 4;
+        int maxChunkZ = Mth.floor(Math.max(from.z, to.z)) >> 4;
+
+        for (int chunkX = minChunkX; chunkX <= maxChunkX; chunkX++) {
+            for (int chunkZ = minChunkZ; chunkZ <= maxChunkZ; chunkZ++) {
+                if (!RegionizedWorldGuard.shouldLoadChunk(level, chunkX, chunkZ)) {
+                    return false;
+                }
+            }
+        }
+
+        return true;
+    }
