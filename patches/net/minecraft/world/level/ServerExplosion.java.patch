+    public CompletableFuture<RegionSpilloverResult> regionSpilloverResult() {
+        List<CompletableFuture<Void>> tasks;
+        synchronized (this.regionSpilloverTasks) {
+            tasks = List.copyOf(this.regionSpilloverTasks);
+        }
+
+        if (tasks.isEmpty()) {
+            return CompletableFuture.completedFuture(new RegionSpilloverResult(0, Map.of()));
+        }
+
+        CompletableFuture<Void> allTasks = CompletableFuture.allOf(tasks.toArray(CompletableFuture[]::new));
+        int timeoutSeconds = RegionizedServerSettings.regionTaskTimeoutSeconds();
+        if (timeoutSeconds > 0) {
+            allTasks = allTasks.orTimeout(timeoutSeconds, TimeUnit.SECONDS);
+        }
+
+        return allTasks.thenApply(ignored -> new RegionSpilloverResult(this.regionSpilloverBlockCount.get(), Map.copyOf(this.regionSpilloverPlayerKnockbacks)));
+    }
+
+    private void scheduleRegionSpillover() {
+        if (!RegionizedTickContext.isRegionThread() || !this.level.getServer().regionizedTaskDispatcher().isRunning()) {
+            return;
+        }
+
+        RegionKey currentRegion = RegionizedTickContext.currentRegion().orElse(null);
+        if (currentRegion == null || currentRegion.level() != this.level.dimension()) {
+            return;
+        }
+
+        for (RegionKey region : this.affectedRegions()) {
+            if (region.equals(currentRegion)) {
+                continue;
+            }
+
+            CompletableFuture<Void> task = this.level.getServer().regionizedTaskDispatcher().submit(region, () -> {
+                ServerExplosion spillover = new ServerExplosion(
+                    this.level,
+                    this.source,
+                    this.damageSource,
+                    this.damageCalculator,
+                    this.center,
+                    this.radius,
+                    this.fire,
+                    this.blockInteraction,
+                    this.randomSeed
+                );
+                int blockCount = spillover.explodeRegionLocal(false);
+                this.regionSpilloverBlockCount.addAndGet(blockCount);
+                for (Map.Entry<Player, Vec3> entry : spillover.getHitPlayers().entrySet()) {
+                    this.regionSpilloverPlayerKnockbacks.put(entry.getKey(), entry.getValue());
+                }
+            });
+            this.regionSpilloverTasks.add(task);
+        }
+    }
+
+    private Set<RegionKey> affectedRegions() {
+        Set<RegionKey> regions = new HashSet<>();
+        float doubleRadius = this.radius * 2.0F;
+        int minChunkX = Mth.floor(this.center.x - doubleRadius - 1.0) >> 4;
+        int maxChunkX = Mth.floor(this.center.x + doubleRadius + 1.0) >> 4;
+        int minChunkZ = Mth.floor(this.center.z - doubleRadius - 1.0) >> 4;
+        int maxChunkZ = Mth.floor(this.center.z + doubleRadius + 1.0) >> 4;
+        int minRegionX = minChunkX >> RegionizedWorldGuard.DEFAULT_REGION_CHUNK_SHIFT;
+        int maxRegionX = maxChunkX >> RegionizedWorldGuard.DEFAULT_REGION_CHUNK_SHIFT;
+        int minRegionZ = minChunkZ >> RegionizedWorldGuard.DEFAULT_REGION_CHUNK_SHIFT;
+        int maxRegionZ = maxChunkZ >> RegionizedWorldGuard.DEFAULT_REGION_CHUNK_SHIFT;
+
+        for (int regionX = minRegionX; regionX <= maxRegionX; regionX++) {
+            for (int regionZ = minRegionZ; regionZ <= maxRegionZ; regionZ++) {
+                regions.add(new RegionKey(this.level.dimension(), regionX, regionZ));
+            }
+        }
+
+        return regions;
+    }
+
+    private List<BlockPos> retainRegionLocalBlocks(List<BlockPos> blocks) {
+        if (!RegionizedTickContext.isRegionThread()) {
+            return blocks;
+        }
+
+        List<BlockPos> localBlocks = new ArrayList<>(blocks.size());
+        for (BlockPos pos : blocks) {
+            if (RegionizedWorldGuard.isRegionThreadFor(this.level, pos)) {
+                localBlocks.add(pos);
+            }
+        }
+
+        return localBlocks;
+    }
+
+    private void retainRegionLocalEntities(List<Entity> entities) {
+        if (!RegionizedTickContext.isRegionThread()) {
+            return;
+        }
+
+        entities.removeIf(entity -> !RegionizedWorldGuard.isRegionThreadFor(this.level, entity.blockPosition()));
+    }
