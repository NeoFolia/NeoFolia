+
+    private static boolean canReadBounds(Level level, AABB box) {
+        int minChunkX = Mth.floor(box.minX) >> 4;
+        int maxChunkX = Mth.floor(box.maxX) >> 4;
+        int minChunkZ = Mth.floor(box.minZ) >> 4;
+        int maxChunkZ = Mth.floor(box.maxZ) >> 4;
+        for (int chunkX = minChunkX; chunkX <= maxChunkX; chunkX++) {
+            for (int chunkZ = minChunkZ; chunkZ <= maxChunkZ; chunkZ++) {
+                if (!RegionizedWorldGuard.shouldLoadChunk(level, chunkX, chunkZ)) {
+                    return false;
+                }
+            }
+        }
+
+        return true;
     }
 
