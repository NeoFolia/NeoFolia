+    /**
+     * Neo: Short-lived holder of dropped item entities. Used mainly for Neo hooks and event logic.
+     * <p>
+     * Captures are thread-local and stacked so region worker threads and nested block updates cannot overwrite each other.
+     */
+    private static final ThreadLocal<java.util.Deque<List<ItemEntity>>> CAPTURED_DROPS = ThreadLocal.withInitial(java.util.ArrayDeque::new);
+
+    /**
+     * Initializes {@link #CAPTURED_DROPS}, starting the drop capture process.
+     */
+    private static void beginCapturingDrops() {
+        CAPTURED_DROPS.get().push(new java.util.ArrayList<>());
+    }
+
+    /**
+     * Ends the current drop capture process and returns its list.
+     */
+    private static List<ItemEntity> stopCapturingDrops() {
+        java.util.Deque<List<ItemEntity>> capturedDrops = CAPTURED_DROPS.get();
+        if (capturedDrops.isEmpty()) {
+            return new java.util.ArrayList<>();
+        }
+        List<ItemEntity> drops = capturedDrops.pop();
+        if (capturedDrops.isEmpty()) {
+            CAPTURED_DROPS.remove();
+        }
+        return drops;
+    }
