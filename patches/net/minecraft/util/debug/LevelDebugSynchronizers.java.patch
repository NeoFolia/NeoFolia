+    private boolean scheduleGlobalIfRegionized(Runnable task) {
+        if (!RegionizedTickContext.isRegionThread()) {
+            return false;
+        }
+
+        if (this.level.getServer().regionizedTaskDispatcher().tryExecuteGlobal(task)) {
+            return true;
+        }
+
+        throw new IllegalStateException("Cannot mutate level debug synchronizer state from region worker while region dispatcher is not running");
+    }
+
+    private <T> DebugValueSource.ValueGetter<T> regionBoundGetter(ChunkPos chunkPos, DebugValueSource.ValueGetter<T> getter) {
+        BlockPos pos = new BlockPos(chunkPos.getMinBlockX(), this.level.getMinY(), chunkPos.getMinBlockZ());
+        return this.regionBoundGetter(pos, getter);
+    }
+
+    private <T> DebugValueSource.ValueGetter<T> regionBoundGetter(BlockPos pos, DebugValueSource.ValueGetter<T> getter) {
+        BlockPos immutablePos = pos.immutable();
+        return () -> RegionizedWorldGuard.callOnRegionAndWait(this.level, immutablePos, "debug value read", getter::get);
+    }
+
+    private <T> DebugValueSource.ValueGetter<T> entityRegionBoundGetter(Entity entity, DebugValueSource.ValueGetter<T> getter) {
+        return () -> RegionizedWorldGuard.callOnEntityRegionAndWait(entity, "debug entity value read", getter::get);
