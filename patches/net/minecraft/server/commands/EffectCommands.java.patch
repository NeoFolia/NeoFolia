+    private static int giveEffect(
+        CommandContext<CommandSourceStack> context, boolean hasSeconds, boolean infinite, boolean hasAmplifier, boolean hasHideParticles
+    ) throws CommandSyntaxException {
+        CommandSourceStack source = context.getSource();
+        if (RegionizedCommandHelper.scheduleGlobalIfRegionized(source, () -> giveEffect(context, hasSeconds, infinite, hasAmplifier, hasHideParticles))) {
+            return 0;
+        }
+
+        return giveEffect(
+            source,
+            EntityArgument.getEntities(context, "targets"),
+            ResourceArgument.getMobEffect(context, "effect"),
+            infinite ? -1 : hasSeconds ? IntegerArgumentType.getInteger(context, "seconds") : null,
+            hasAmplifier ? IntegerArgumentType.getInteger(context, "amplifier") : 0,
+            hasHideParticles ? !BoolArgumentType.getBool(context, "hideParticles") : true
         );
     }
 
