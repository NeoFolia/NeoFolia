+    private static int spectate(CommandContext<CommandSourceStack> context, boolean hasTarget, boolean hasPlayer) throws CommandSyntaxException {
+        CommandSourceStack source = context.getSource();
+        if (RegionizedCommandHelper.scheduleGlobalIfRegionized(source, () -> spectate(context, hasTarget, hasPlayer))) {
+            return 0;
+        }
+
+        return spectate(
+            source,
+            hasTarget ? EntityArgument.getEntity(context, "target") : null,
+            hasPlayer ? EntityArgument.getPlayer(context, "player") : source.getPlayerOrException()
+        );
+    }
