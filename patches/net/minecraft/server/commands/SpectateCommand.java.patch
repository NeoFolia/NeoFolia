     private static int spectate(CommandSourceStack source, @Nullable Entity target, ServerPlayer player) throws CommandSyntaxException {
+        Component targetName;
+        if (target != null && source.getServer().regionizedTaskDispatcher().isRunning()) {
+            ServerLevel playerLevel = player.level();
+            if (target.level() instanceof ServerLevel targetLevel) {
+                RegionKey playerRegion = RegionizedWorldGuard.regionFor(playerLevel, player.blockPosition());
+                RegionKey targetRegion = RegionizedWorldGuard.regionFor(targetLevel, target.blockPosition());
+                if (!playerRegion.equals(targetRegion)) {
+                    targetName = spectateAcrossRegions(source, target, player, playerRegion, targetRegion);
+                    return sendSuccess(source, targetName);
+                }
+            }
+        }
+
+        targetName = spectateOnOwningRegions(source, target, player);
+        return sendSuccess(source, targetName);
+    }
+
+    private static @Nullable Component spectateAcrossRegions(
+        CommandSourceStack source,
+        Entity target,
+        ServerPlayer player,
+        RegionKey playerRegion,
+        RegionKey targetRegion
+    ) throws CommandSyntaxException {
+        AtomicReference<Component> targetName = new AtomicReference<>();
+        AtomicReference<CommandSyntaxException> failure = new AtomicReference<>();
+        source.getServer().regionizedTaskDispatcher().awaitRegions("spectate command", List.of(playerRegion, targetRegion), playerRegion, () -> {
+            try {
+                targetName.set(spectateOnReservedRegions(target, player));
+            } catch (CommandSyntaxException ex) {
+                failure.set(ex);
+            }
+        });
+        if (failure.get() != null) {
+            throw failure.get();
+        }
+
+        return targetName.get();
+    }
+
