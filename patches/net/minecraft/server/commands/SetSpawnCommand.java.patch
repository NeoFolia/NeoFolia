+    private static int setSpawn(CommandContext<CommandSourceStack> context, boolean hasTargets, boolean hasPosition, boolean hasRotation)
+        throws CommandSyntaxException {
+        CommandSourceStack source = context.getSource();
+        if (RegionizedCommandHelper.scheduleGlobalIfRegionized(source, () -> setSpawn(context, hasTargets, hasPosition, hasRotation))) {
+            return 0;
+        }
+
+        return setSpawn(
+            source,
+            hasTargets ? EntityArgument.getPlayers(context, "targets") : Collections.singleton(source.getPlayerOrException()),
+            hasPosition ? BlockPosArgument.getSpawnablePos(context, "pos") : BlockPos.containing(source.getPosition()),
+            hasRotation ? RotationArgument.getRotation(context, "rotation") : WorldCoordinates.ZERO_ROTATION
         );
     }
 
