+        if (RegionizedCommandHelper.scheduleGlobalIfRegionized(source, () -> rotate(context, entityFacing, alternateArgument))) {
+            return 0;
+        }
+
+        Entity target = EntityArgument.getEntity(context, "target");
+        if (entityFacing) {
+            EntityAnchorArgument.Anchor anchor = alternateArgument ? EntityAnchorArgument.getAnchor(context, "facingAnchor") : EntityAnchorArgument.Anchor.FEET;
+            Entity facingEntity = EntityArgument.getEntity(context, "facingEntity");
+            Vec3 facingPosition = RegionizedCommandHelper.callOnEntityRegion(source, facingEntity, () -> anchor.apply(facingEntity));
+            return rotate(source, target, new LookAt.LookAtPosition(facingPosition));
+        }
+
+        if (alternateArgument) {
+            return rotate(source, target, new LookAt.LookAtPosition(Vec3Argument.getVec3(context, "facingLocation")));
+        }
+
+        return rotate(source, target, RotationArgument.getRotation(context, "rotation"));
+    }
