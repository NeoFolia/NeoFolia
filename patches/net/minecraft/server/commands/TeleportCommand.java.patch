+    private static int teleportSelfToPos(CommandContext<CommandSourceStack> context) throws CommandSyntaxException {
+        CommandSourceStack source = context.getSource();
+        if (RegionizedCommandHelper.scheduleGlobalIfRegionized(source, () -> teleportSelfToPos(context))) {
+            return 0;
+        }
+
+        return teleportToPos(
+            source,
+            Collections.singleton(source.getEntityOrException()),
+            source.getLevel(),
+            Vec3Argument.getCoordinates(context, "location"),
+            null,
+            null
+        );
+    }
+
+    private static int teleportSelfToEntity(CommandContext<CommandSourceStack> context) throws CommandSyntaxException {
+        CommandSourceStack source = context.getSource();
+        if (RegionizedCommandHelper.scheduleGlobalIfRegionized(source, () -> teleportSelfToEntity(context))) {
+            return 0;
+        }
+
+        return teleportToEntity(source, Collections.singleton(source.getEntityOrException()), EntityArgument.getEntity(context, "destination"));
+    }
+
+    private static int teleportTargetsToEntity(CommandContext<CommandSourceStack> context) throws CommandSyntaxException {
+        CommandSourceStack source = context.getSource();
+        if (RegionizedCommandHelper.scheduleGlobalIfRegionized(source, () -> teleportTargetsToEntity(context))) {
+            return 0;
+        }
+
+        return teleportToEntity(source, EntityArgument.getEntities(context, "targets"), EntityArgument.getEntity(context, "destination"));
+    }
+
+    private static int teleportTargetsToPos(CommandContext<CommandSourceStack> context, TeleportCommand.PosMode mode) throws CommandSyntaxException {
+        CommandSourceStack source = context.getSource();
+        if (RegionizedCommandHelper.scheduleGlobalIfRegionized(source, () -> teleportTargetsToPos(context, mode))) {
+            return 0;
+        }
+
+        LookAt lookAt = switch (mode) {
+            case PLAIN, ROTATION -> null;
+            case FACING_ENTITY -> lookAtEntitySnapshot(source, EntityArgument.getEntity(context, "facingEntity"), EntityAnchorArgument.Anchor.FEET);
+            case FACING_ENTITY_ANCHOR -> lookAtEntitySnapshot(source, EntityArgument.getEntity(context, "facingEntity"), EntityAnchorArgument.getAnchor(context, "facingAnchor"));
+            case FACING_LOCATION -> new LookAt.LookAtPosition(Vec3Argument.getVec3(context, "facingLocation"));
+        };
+
+        return teleportToPos(
+            source,
+            EntityArgument.getEntities(context, "targets"),
+            source.getLevel(),
+            Vec3Argument.getCoordinates(context, "location"),
+            mode == TeleportCommand.PosMode.ROTATION ? RotationArgument.getRotation(context, "rotation") : null,
+            lookAt
+        );
+    }
