+    private static int damage(CommandContext<CommandSourceStack> context, DamageCommand.DamageMode mode) throws CommandSyntaxException {
+        CommandSourceStack stack = context.getSource();
+        if (RegionizedCommandHelper.scheduleGlobalIfRegionized(stack, () -> damage(context, mode))) {
+            return 0;
+        }
+
+        DamageSource source = switch (mode) {
+            case GENERIC -> stack.getLevel().damageSources().generic();
+            case TYPE -> new DamageSource(ResourceArgument.getResource(context, "damageType", Registries.DAMAGE_TYPE));
+            case AT -> new DamageSource(
+                ResourceArgument.getResource(context, "damageType", Registries.DAMAGE_TYPE),
+                Vec3Argument.getVec3(context, "location")
+            );
+            case BY -> new DamageSource(
+                ResourceArgument.getResource(context, "damageType", Registries.DAMAGE_TYPE),
+                EntityArgument.getEntity(context, "entity")
+            );
+            case FROM -> new DamageSource(
+                ResourceArgument.getResource(context, "damageType", Registries.DAMAGE_TYPE),
+                EntityArgument.getEntity(context, "entity"),
+                EntityArgument.getEntity(context, "cause")
+            );
+        };
+        return damage(stack, EntityArgument.getEntity(context, "target"), FloatArgumentType.getFloat(context, "amount"), source);
+    }
+
     private static int damage(CommandSourceStack stack, Entity target, float amount, DamageSource source) throws CommandSyntaxException {
-        if (target.hurtServer(stack.getLevel(), source, amount)) {
-            stack.sendSuccess(() -> Component.translatable("commands.damage.success", amount, target.getDisplayName()), true);
+        DamageResult result = RegionizedCommandHelper.callOnEntityRegion(stack, target, () -> {
+            boolean hurt = target.hurtServer(stack.getLevel(), source, amount);
+            return new DamageResult(hurt, target.getDisplayName());
+        });
+        if (result.hurt()) {
+            stack.sendSuccess(() -> Component.translatable("commands.damage.success", amount, result.targetName()), true);
             return 1;
         } else {
             throw ERROR_INVULNERABLE.create();
         }
+    }
+
+    private record DamageResult(boolean hurt, Component targetName) {
