+    private static int perform(CommandContext<CommandSourceStack> context, AdvancementCommands.Action action, AdvancementCommands.Mode mode, boolean showAdvancements)
+        throws CommandSyntaxException {
+        CommandSourceStack source = context.getSource();
+        if (RegionizedCommandHelper.scheduleGlobalIfRegionized(source, () -> perform(context, action, mode, showAdvancements))) {
+            return 0;
+        }
+
+        return perform(
+            source,
+            EntityArgument.getPlayers(context, "targets"),
+            action,
+            getAdvancements(context, ResourceKeyArgument.getAdvancement(context, "advancement"), mode),
+            showAdvancements
+        );
+    }
+
