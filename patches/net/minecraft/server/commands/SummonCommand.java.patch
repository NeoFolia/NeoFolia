+    private static int spawnEntity(CommandContext<CommandSourceStack> context, SummonMode mode) throws CommandSyntaxException {
+        CommandSourceStack source = context.getSource();
+        Vec3 pos = mode == SummonMode.SOURCE_POSITION ? source.getPosition() : Vec3Argument.getVec3(context, "pos");
