+    private static int sendParticles(CommandContext<CommandSourceStack> context, boolean hasPosition, boolean hasSpread, boolean force, boolean hasViewers)
+        throws CommandSyntaxException {
+        CommandSourceStack source = context.getSource();
+        if (RegionizedCommandHelper.scheduleGlobalIfRegionized(source, () -> sendParticles(context, hasPosition, hasSpread, force, hasViewers))) {
+            return 0;
+        }
+
+        return sendParticles(
+            source,
+            ParticleArgument.getParticle(context, "name"),
+            hasPosition ? Vec3Argument.getVec3(context, "pos") : source.getPosition(),
+            hasSpread ? Vec3Argument.getVec3(context, "delta") : Vec3.ZERO,
+            hasSpread ? FloatArgumentType.getFloat(context, "speed") : 0.0F,
+            hasSpread ? IntegerArgumentType.getInteger(context, "count") : 0,
+            force,
+            hasViewers ? EntityArgument.getPlayers(context, "viewers") : source.getServer().getPlayerList().getPlayersAcrossRegions()
+        );
+    }
