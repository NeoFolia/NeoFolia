+    private static void teleportEntity(CommandSourceStack source, ServerLevel level, Entity entity, double targetX, double targetY, double targetZ) {
+        if (entity.level() == level && source.getServer().regionizedTaskDispatcher().isRunning()) {
+            RegionKey entityRegion = RegionizedWorldGuard.regionFor(level, entity.blockPosition());
+            RegionKey targetRegion = RegionizedWorldGuard.regionFor(level, BlockPos.containing(targetX, targetY, targetZ));
+            if (!entityRegion.equals(targetRegion)) {
+                source.getServer()
+                    .regionizedTaskDispatcher()
+                    .awaitRegions("spread players teleport", Set.of(entityRegion, targetRegion), entityRegion, () -> {
+                        teleportEntityOnRegion(level, entity, targetX, targetY, targetZ);
+                    });
+                return;
+            }
+        }
+
+        RegionizedCommandHelper.callOnEntityRegion(source, entity, () -> {
+            teleportEntityOnRegion(level, entity, targetX, targetY, targetZ);
+            return null;
+        });
+    }
+
+    private static void teleportEntityOnRegion(ServerLevel level, Entity entity, double targetX, double targetY, double targetZ) {
+        net.neoforged.neoforge.event.entity.EntityTeleportEvent.SpreadPlayersCommand event = net.neoforged.neoforge.event.EventHooks.onEntityTeleportSpreadPlayersCommand(
+            entity,
+            level,
+            targetX,
+            targetY,
+            targetZ
+        );
+        if (!event.isCanceled()) {
+            entity.teleportTo(level, event.getTargetX(), event.getTargetY(), event.getTargetZ(), Set.of(), entity.getYRot(), entity.getXRot(), true);
+        }
     }
 
