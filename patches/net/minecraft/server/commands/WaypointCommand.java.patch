+    private static int setWaypointStyle(CommandContext<CommandSourceStack> context, boolean hasStyle) throws CommandSyntaxException {
+        CommandSourceStack source = context.getSource();
+        if (RegionizedCommandHelper.scheduleGlobalIfRegionized(source, () -> setWaypointStyle(context, hasStyle))) {
+            return 0;
+        }
+
+        ResourceKey<WaypointStyleAsset> style = hasStyle
+            ? ResourceKey.create(WaypointStyleAssets.ROOT_ID, IdentifierArgument.getId(context, "style"))
+            : WaypointStyleAssets.DEFAULT;
+        return setWaypointStyle(source, WaypointArgument.getWaypoint(context, "waypoint"), style);
+    }
+
+    private static int setWaypointColor(CommandContext<CommandSourceStack> context, ColorMode mode) throws CommandSyntaxException {
+        CommandSourceStack source = context.getSource();
+        if (RegionizedCommandHelper.scheduleGlobalIfRegionized(source, () -> setWaypointColor(context, mode))) {
+            return 0;
+        }
+
+        WaypointTransmitter waypoint = WaypointArgument.getWaypoint(context, "waypoint");
+        if (mode == ColorMode.NAMED) {
+            return setWaypointColor(source, waypoint, ColorArgument.getColor(context, "color"));
+        } else {
+            return setWaypointColor(source, waypoint, HexColorArgument.getHexColor(context, "color"));
+        }
+    }
+
