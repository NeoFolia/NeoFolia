     private static void mutateIcon(CommandSourceStack source, WaypointTransmitter waypoint, Consumer<Waypoint.Icon> iconConsumer) {
+        if (waypoint instanceof LivingEntity livingEntity) {
+            RegionizedCommandHelper.callOnEntityRegion(source, livingEntity, () -> {
+                mutateIconOnCurrentThread(source, waypoint, iconConsumer);
+                return null;
+            });
+            return;
+        }
+
+        mutateIconOnCurrentThread(source, waypoint, iconConsumer);
+    }
