+    private boolean executeOnPlayerRegionAndWaitIfNeeded(String reason, Runnable task) {
+        return this.callOnPlayerRegionAndWaitIfNeeded(reason, () -> {
+            task.run();
+            return Boolean.TRUE;
+        }) != null;
+    }
+
+    private <T> @Nullable RegionCallResult<T> callOnPlayerRegionAndWaitIfNeeded(String reason, java.util.function.Supplier<T> task) {
+        if (!this.server.regionizedTaskDispatcher().isRunning()) {
+            return null;
+        }
+
+        var region = RegionizedWorldGuard.regionFor(this.level(), this.blockPosition());
+        if (RegionizedTickContext.currentRegion().map(region::equals).orElse(false)) {
+            return null;
+        }
+
+        if (RegionizedTickContext.isRegionThread()) {
+            throw new IllegalStateException("Cannot wait for " + reason + " from another region worker");
+        }
+
+        return new RegionCallResult<>(true, RegionizedWorldGuard.callOnPlayerRegionAndWait(this, reason, task));
+    }
+
+    private record RegionCallResult<T>(boolean completed, @Nullable T result) {
     }
 
