+            if (this.level.getServer().regionizedTaskDispatcher().tryExecuteGlobal("chunk-task-ticket-release", release)) {
+                return;
+            }
+
+            this.mainThreadExecutor.execute(release);
+            return;
+        }
+
+        release.run();
+    }
