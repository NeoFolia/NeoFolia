+            MIN_PLAYER_TICKET_UPDATES_PER_RUN,
+            Math.min(MAX_PLAYER_TICKET_UPDATES_PER_RUN, RegionizedServerSettings.playerChunkLoadConcurrency() * 4)
+        );
+    }
+
+    private int maxDistanceTrackerUpdatesPerRun() {
+        if (this.level == null || !RegionizedServerSettings.regionizedChunkTicksEnabled() || !this.level.getServer().regionizedTaskDispatcher().isRunning()) {
+            return Integer.MAX_VALUE;
+        }
+
+        return Math.max(
+            MIN_DISTANCE_TRACKER_UPDATES_PER_RUN,
+            Math.min(MAX_DISTANCE_TRACKER_UPDATES_PER_RUN, RegionizedServerSettings.playerChunkLoadConcurrency() * 64)
