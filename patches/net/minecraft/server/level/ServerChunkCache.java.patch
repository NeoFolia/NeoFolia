+    private void tickSpawningChunks(
+        List<LevelChunk> spawningChunks, long timeDiff, List<MobCategory> spawningCategories, NaturalSpawner.SpawnState spawnCookie
+    ) {
+        if (!RegionizedServerSettings.regionizedChunkTicksEnabled() || !this.level.getServer().regionizedTaskDispatcher().isRunning()) {
+            for (LevelChunk chunk : spawningChunks) {
+                this.tickSpawningChunk(chunk, timeDiff, spawningCategories, spawnCookie);
+            }
+            return;
+        }
+
+        Map<RegionKey, List<LevelChunk>> chunksByRegion = new LinkedHashMap<>();
+        for (LevelChunk chunk : spawningChunks) {
+            chunksByRegion.computeIfAbsent(RegionizedWorldGuard.regionFor(this.level, chunk.getPos()), key -> new ObjectArrayList<>()).add(chunk);
+        }
+
+        Map<RegionKey, Runnable> tasksByRegion = new LinkedHashMap<>();
+        chunksByRegion.forEach((region, chunks) -> tasksByRegion.put(region, () -> {
+            for (LevelChunk chunk : chunks) {
+                this.tickSpawningChunk(chunk, timeDiff, spawningCategories, spawnCookie);
+            }
+        }));
+        this.level.getServer().regionizedTaskDispatcher().executeCoalescedAll("spawning-chunk-ticks", tasksByRegion);
+    }
