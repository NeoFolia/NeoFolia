+    private void tickCustomSpawnersRegionized() {
+        Map<RegionKey, Runnable> tasksByRegion = new LinkedHashMap<>();
+        for (RegionKey region : this.chunkMap.spawningOwnerRegions()) {
+            tasksByRegion.put(region, () -> {
+                if (!RegionizedWorldGuard.localPlayersForCurrentRegion(this.level).isEmpty()) {
+                    this.level.tickCustomSpawners(this.spawnEnemies);
+                }
+            });
