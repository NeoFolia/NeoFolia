+    private void tickSpawningChunksRegionized(long timeDiff, boolean doMobSpawning) {
+        Map<RegionKey, Runnable> tasksByRegion = new LinkedHashMap<>();
+        for (RegionKey region : this.chunkMap.spawningOwnerRegions()) {
+            tasksByRegion.put(region, () -> this.tickSpawningChunksForRegion(region, timeDiff, doMobSpawning));
+        }
+
+        this.level.getServer().regionizedTaskDispatcher().executeCoalescedAll("spawning-chunk-ticks", tasksByRegion);
+    }
+
+    private void tickSpawningChunksForRegion(RegionKey region, long timeDiff, boolean doMobSpawning) {
+        int chunkCount = this.chunkMap.getNaturalSpawnChunkCountForRegion(region);
+        NaturalSpawner.SpawnState spawnCookie = NaturalSpawner.createState(
+            chunkCount,
+            RegionizedWorldGuard.loadedEntitiesForCurrentRegion(this.level),
+            this::getFullChunk,
+            new LocalMobCapCalculator(this.chunkMap)
+        );
+        RegionizedWorldGuard.currentWorldData(this.level).lastSpawnState = spawnCookie;
+        List<MobCategory> spawningCategories;
+        if (doMobSpawning && !RegionizedWorldGuard.localPlayersForCurrentRegion(this.level).isEmpty()) {
+            boolean spawnPersistent = this.level.getGameTime() % 400L == 0L;
+            spawningCategories = NaturalSpawner.getFilteredSpawningCategories(spawnCookie, true, this.spawnEnemies, spawnPersistent);
+        } else {
+            spawningCategories = List.of();
+        }
+
+        List<LevelChunk> spawningChunks = new ObjectArrayList<>();
+        this.chunkMap.collectSpawningChunksForRegion(region, spawningChunks);
+        Util.shuffle(spawningChunks, RegionizedTickContext.currentRandom().orElse(this.level.getRandom()));
+        for (LevelChunk chunk : spawningChunks) {
+            this.tickSpawningChunk(chunk, timeDiff, spawningCategories, spawnCookie);
+        }
+    }
+
+    private void tickSpawningChunks(
+        List<LevelChunk> spawningChunks, long timeDiff, List<MobCategory> spawningCategories, NaturalSpawner.SpawnState spawnCookie
+    ) {
+        if (!RegionizedServerSettings.regionizedChunkTicksEnabled() || !this.level.getServer().regionizedTaskDispatcher().isRunning()) {
+            for (LevelChunk chunk : spawningChunks) {
+                this.tickSpawningChunk(chunk, timeDiff, spawningCategories, spawnCookie);
+            }
+            return;
+        }
+
+        Map<RegionKey, List<LevelChunk>> chunksByRegion = new LinkedHashMap<>();
+        for (LevelChunk chunk : spawningChunks) {
+            chunksByRegion.computeIfAbsent(RegionizedWorldGuard.regionFor(this.level, chunk.getPos()), key -> new ObjectArrayList<>()).add(chunk);
+        }
+
+        Map<RegionKey, Runnable> tasksByRegion = new LinkedHashMap<>();
+        chunksByRegion.forEach((region, chunks) -> tasksByRegion.put(region, () -> {
+            for (LevelChunk chunk : chunks) {
+                this.tickSpawningChunk(chunk, timeDiff, spawningCategories, spawnCookie);
+            }
+        }));
+        this.level.getServer().regionizedTaskDispatcher().executeCoalescedAll("spawning-chunk-ticks", tasksByRegion);
+    }
