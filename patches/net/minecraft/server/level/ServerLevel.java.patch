+    private void tickEntitiesRegionized(TickRateManager tickRateManager) {
+        Map<RegionKey, List<Entity>> entitiesByRegion = new LinkedHashMap<>();
+        for (Entity entity : this.entityTickList.snapshot()) {
+            ChunkPos chunkPos = entity.chunkPosition();
+            entitiesByRegion.computeIfAbsent(this.regionKeyForChunk(chunkPos), key -> new ArrayList<>()).add(entity);
+        }
+
+        Map<RegionKey, Runnable> tasksByRegion = new LinkedHashMap<>();
+        entitiesByRegion.forEach((region, entities) -> tasksByRegion.put(region, () -> {
+            for (Entity entity : entities) {
+                this.tickEntityIfNeeded(entity, tickRateManager);
+            }
+        }));
+
+        this.server.regionizedTaskDispatcher().executeCoalescedAll("entity-ticks", tasksByRegion);
+    }
+
