+    public void tickChunkRegionized(LevelChunk chunk, int tickSpeed) {
+        this.ensureRegionThreadFor(chunk.getPos(), "regionized chunk tick");
+        RandomSource random = RegionizedTickContext.currentRandom().orElse(this.random);
+        ChunkPos chunkPos = chunk.getPos();
+        int minX = chunkPos.getMinBlockX();
+        int minZ = chunkPos.getMinBlockZ();
+        ProfilerFiller profiler = Profiler.get();
+        profiler.push("iceandsnow");
+
+        for (int i = 0; i < tickSpeed; i++) {
+            if (random.nextInt(48) == 0) {
+                this.tickPrecipitation(getRegionizedBlockRandomPos(random, minX, 0, minZ, 15));
+            }
+        }
+
+        profiler.popPush("tickBlocks");
+        if (tickSpeed > 0) {
+            LevelChunkSection[] sections = chunk.getSections();
+
+            for (int sectionIndex = 0; sectionIndex < sections.length; sectionIndex++) {
+                LevelChunkSection section = sections[sectionIndex];
+                if (section.isRandomlyTicking()) {
+                    int sectionY = chunk.getSectionYFromSectionIndex(sectionIndex);
+                    int minYInSection = SectionPos.sectionToBlockCoord(sectionY);
+
+                    for (int ix = 0; ix < tickSpeed; ix++) {
+                        BlockPos pos = getRegionizedBlockRandomPos(random, minX, minYInSection, minZ, 15);
+                        profiler.push("randomTick");
+                        BlockState blockState = section.getBlockState(pos.getX() - minX, pos.getY() - minYInSection, pos.getZ() - minZ);
+                        if (blockState.isRandomlyTicking()) {
+                            blockState.randomTick(this, pos, random);
+                        }
+
+                        FluidState fluidState = blockState.getFluidState();
+                        if (fluidState.isRandomlyTicking()) {
+                            fluidState.randomTick(this, pos, random);
+                        }
+
+                        profiler.pop();
+                    }
+                }
+            }
+        }
+
+        profiler.pop();
+    }
+
+    private static BlockPos getRegionizedBlockRandomPos(RandomSource random, int xo, int yo, int zo, int yMask) {
+        int value = random.nextInt();
+        return new BlockPos(xo + (value & 15), yo + (value >> 16 & yMask), zo + (value >> 8 & 15));
+    }
