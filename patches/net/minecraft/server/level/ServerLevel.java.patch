+    private void tickPendingTicks(long tick) {
+        ProfilerFiller profiler = Profiler.get();
+        if (!RegionizedServerSettings.regionizedScheduledTicksEnabled() || !this.server.regionizedTaskDispatcher().isRunning()) {
+            profiler.push("blockTicks");
+            this.blockTicks.tick(tick, MAX_SCHEDULED_TICKS_PER_TICK, this::tickBlock);
+            profiler.popPush("fluidTicks");
+            this.fluidTicks.tick(tick, MAX_SCHEDULED_TICKS_PER_TICK, this::tickFluid);
+            profiler.pop();
+            return;
+        }
+
+        profiler.push("blockTicks");
+        this.blockTicks.tickRegionized(tick, MAX_SCHEDULED_TICKS_PER_TICK, ticks -> this.runScheduledTicksByRegion("regionized block ticks", ticks, this::tickBlock));
+        profiler.popPush("fluidTicks");
+        this.fluidTicks.tickRegionized(tick, MAX_SCHEDULED_TICKS_PER_TICK, ticks -> this.runScheduledTicksByRegion("regionized fluid ticks", ticks, this::tickFluid));
+        profiler.pop();
+    }
+
+    private <T> void runScheduledTicksByRegion(String description, List<ScheduledTick<T>> ticks, BiConsumer<BlockPos, T> output) {
+        if (ticks.isEmpty()) {
+            return;
+        }
+
+        Map<RegionKey, List<ScheduledTick<T>>> ticksByRegion = new LinkedHashMap<>();
+        for (ScheduledTick<T> scheduledTick : ticks) {
+            ticksByRegion.computeIfAbsent(this.regionKeyForBlock(scheduledTick.pos()), key -> new ObjectArrayList<>()).add(scheduledTick);
+        }
+
+        Map<RegionKey, Runnable> tasksByRegion = new LinkedHashMap<>();
+        ticksByRegion.forEach((region, scheduledTicks) -> tasksByRegion.put(region, () -> {
+            for (ScheduledTick<T> scheduledTick : scheduledTicks) {
+                this.ensureRegionThreadFor(scheduledTick.pos(), description);
+                output.accept(scheduledTick.pos(), scheduledTick.type());
+            }
+        }));
+        this.server.regionizedTaskDispatcher().awaitAll(description + " for " + this.dimension().identifier(), tasksByRegion);
+    }
