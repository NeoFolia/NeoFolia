+    private void refreshSleepingPlayerList() {
+        if (RegionizedTickContext.isRegionThread()) {
+            if (this.sleepStatusRefreshQueued.compareAndSet(false, true)) {
+                if (!this.server.regionizedTaskDispatcher().tryExecuteGlobal(() -> {
+                    try {
+                        this.updateSleepingPlayerList();
+                    } finally {
+                        this.sleepStatusRefreshQueued.set(false);
+                    }
+                })) {
+                    this.sleepStatusRefreshQueued.set(false);
+                    throw new IllegalStateException("Cannot refresh sleeping player list from region worker while region dispatcher is not running");
+                }
+            }
+            return;
+        }
+
+        this.updateSleepingPlayerList();
+    }
+
+    private SleepCounts countSleepers(List<ServerPlayer> players) {
+        int activePlayers = 0;
+        int sleepingPlayers = 0;
+        int deepSleepingPlayers = 0;
+
+        for (ServerPlayer player : players) {
+            SleepState state = this.sleepState(player);
+            if (state.active()) {
+                activePlayers++;
+                if (state.sleeping()) {
+                    sleepingPlayers++;
+                }
+
+                if (state.deepSleeping()) {
+                    deepSleepingPlayers++;
+                }
+            }
+        }
+
+        return new SleepCounts(activePlayers, sleepingPlayers, deepSleepingPlayers);
+    }
+
+    private SleepState sleepState(ServerPlayer player) {
+        if (this.server.regionizedTaskDispatcher().isRunning() && !RegionizedWorldGuard.isOnPlayerRegion(player)) {
+            return RegionizedWorldGuard.callOnPlayerRegionAndWait(player, "sleep state snapshot", () -> SleepState.from(player));
+        }
+
+        return SleepState.from(player);
+    }
+
+    private record SleepCounts(int activePlayers, int sleepingPlayers, int deepSleepingPlayers) {
+    }
+
+    private record SleepState(boolean active, boolean sleeping, boolean deepSleeping) {
+        private static SleepState from(ServerPlayer player) {
+            return new SleepState(!player.isSpectator(), player.isSleeping(), player.isSleepingLongEnough());
+        }
+    }
