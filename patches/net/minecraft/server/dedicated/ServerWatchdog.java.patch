+    private static void logImmediateThreadDump(long mainThreadId) {
+        try {
+            ThreadMXBean threadMXBean = ManagementFactory.getThreadMXBean();
+            ThreadInfo[] threadInfos = threadMXBean.dumpAllThreads(true, true);
+            StringBuilder builder = new StringBuilder();
+            builder.append("Immediate watchdog thread dump before crash report generation:\n");
+
+            for (ThreadInfo threadInfo : threadInfos) {
+                if (threadInfo.getThreadId() == mainThreadId) {
+                    builder.append(">>> SERVER THREAD AT WATCHDOG TIME <<<\n");
+                }
+
+                builder.append(net.neoforged.neoforge.logging.ThreadInfoUtil.getEntireStacktrace(threadInfo));
+                builder.append('\n');
+            }
+
+            LOGGER.error(LogUtils.FATAL_MARKER, "{}", builder);
+        } catch (Throwable throwable) {
+            LOGGER.error(LogUtils.FATAL_MARKER, "Failed to write immediate watchdog thread dump", throwable);
+        }
+    }
