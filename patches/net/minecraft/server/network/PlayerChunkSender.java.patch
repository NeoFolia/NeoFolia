+    private List<RegionKey> collectPendingChunkRegions(
+        ServerLevel level,
+        ChunkMap chunkMap,
+        ChunkPos playerPos,
+        @Nullable RegionKey excludedRegion,
+        int maxRegions
+    ) {
+        long[] pendingChunks = this.pendingChunkSnapshotIfReady();
+        if (pendingChunks.length == 0) {
+            return List.of();
+        }
+
+        Map<RegionKey, Integer> closestDistanceByRegion = new LinkedHashMap<>();
+        for (long pendingChunk : pendingChunks) {
+            if (chunkMap.getChunkToSend(pendingChunk) == null) {
+                continue;
+            }
+
+            RegionKey region = RegionizedWorldGuard.regionFor(level, ChunkPos.unpack(pendingChunk));
+            if (region.equals(excludedRegion)) {
+                continue;
+            }
+
+            int distance = playerPos.distanceSquared(ChunkPos.unpack(pendingChunk));
+            closestDistanceByRegion.merge(region, distance, Math::min);
+        }
+
+        if (closestDistanceByRegion.isEmpty()) {
+            return List.of();
+        }
+
+        return closestDistanceByRegion.entrySet()
+            .stream()
+            .sorted(Map.Entry.comparingByValue())
+            .limit(maxRegions)
+            .map(Map.Entry::getKey)
+            .toList();
+    }
