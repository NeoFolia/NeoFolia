+
+        ServerGamePacketListenerImpl connection = player.connection;
+        List<ChunkPos> deferredForgetChunks = List.of();
+        try {
+            RegionizedWorldGuard.sendPreparedPacketToPlayer(player, ClientboundChunkBatchStartPacket.INSTANCE, false);
